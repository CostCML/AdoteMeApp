<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.CadastroAdotantePage"
    Title="Cadastro de Adotante">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Entry Placeholder="Nome completo" />
            <Entry Placeholder="CPF" />
            <Entry Placeholder="RG" />
            <Entry Placeholder="Telefone" />
            <Entry Placeholder="E-mail" />
            <Entry Placeholder="Endereço" />
            <Entry Placeholder="Renda mensal" />
            <Entry Placeholder="Senha" IsPassword="True" />
            <Entry Placeholder="Confirmar senha" IsPassword="True" />

            <Button Text="Cadastrar" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>