<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.CadastroAdotantePage"
    Title="Cadastro de Adotante">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <Entry x:Name="NomeEntry" Placeholder="Nome Completo" />
            <Entry x:Name="CpfEntry" Placeholder="CPF" />
            <Entry Placeholder="RG" />
            <Entry Placeholder="Telefone" />
            <Entry x:Name="EmailEntry" Placeholder="E-mail" />
            <Entry Placeholder="Endereço" />
            <Entry Placeholder="Renda mensal" />
            <Entry x:Name="SenhaEntry" Placeholder="Senha" />
            <Entry x:Name="ConfirmarSenhaEntry" Placeholder="Confirme sua senhao" />

            <Button Clicked="OnCadastrarClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>