<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.AnimaisDisponiveisPage"
    Title="Animais Disponíveis">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Animais para adoção"
                FontSize="28"
                FontAttributes="Bold" />

            <CollectionView
                x:Name="AnimaisCollection">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame
                            Padding="15"
                            Margin="0,5"
                            BorderColor="LightGray">

                            <VerticalStackLayout
                                Spacing="8">

                                <Image
                                    Source="{Binding FotoPath}"
                                    HeightRequest="220"
                                    Aspect="AspectFill" />

                                <Label
                                    Text="{Binding Nome}"
                                    FontSize="22"
                                    FontAttributes="Bold" />

                                <Label
                                    Text="{Binding Especie}" />

                                <Label
                                    Text="{Binding Raca}" />

                                <Label
                                    Text="{Binding Idade}" />

                                <Label
                                    Text="{Binding Sexo}" />

                                <Label
                                    Text="{Binding Porte}" />

                                <Label
                                    Text="{Binding Descricao}" />

                                <Label
                                    Text="{Binding StatusAdocao}"
                                    TextColor="Green"
                                    FontAttributes="Bold" />

                                <Button
                                    Text="Solicitar adoção"
                                    Clicked="OnSolicitarClicked"
                                    CommandParameter="{Binding .}" />

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>