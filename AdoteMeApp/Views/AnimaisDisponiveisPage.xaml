<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.AnimaisDisponiveisPage"
    BackgroundColor="#F5F5F5"
    Title="Animais">

    <CollectionView
        x:Name="AnimaisCollection"
        Margin="15">

        <CollectionView.ItemTemplate>

            <DataTemplate>

                <Frame
                    Margin="0,0,0,20"
                    Padding="0"
                    CornerRadius="20"
                    HasShadow="True"
                    BackgroundColor="White">

                    <VerticalStackLayout>

                        <!-- FOTO -->

                        <Image
                            Source="{Binding Foto}"
                            HeightRequest="220"
                            Aspect="AspectFill" />

                        <VerticalStackLayout
                            Padding="15"
                            Spacing="10">

                            <!-- NOME -->

                            <Label
                                Text="{Binding Nome}"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#222" />

                            <!-- INFO -->

                            <Label
                                Text="{Binding Sexo}"
                                FontSize="15"
                                TextColor="#666" />

                            <Label
                                Text="{Binding Idade}"
                                FontSize="15"
                                TextColor="#666" />

                            <Label
                                Text="{Binding Porte}"
                                FontSize="15"
                                TextColor="#666" />

                            <!-- ONG -->

                            <Label
                                Text="{Binding NomeONG}"
                                FontSize="14"
                                TextColor="#5B2BE0" />

                            <!-- BOTÕES -->

                            <Grid
                                ColumnDefinitions="*,*"
                                Margin="0,10,0,0">

                                <Button
                                    Grid.Column="0"
                                    Text="❤️ Favoritar"
                                    BackgroundColor="#EFEAFE"
                                    TextColor="#5B2BE0"
                                    CornerRadius="15" />

                                <Button
                                    Grid.Column="1"
                                    Text="Quero Adotar"
                                    BackgroundColor="#5B2BE0"
                                    TextColor="White"
                                    CornerRadius="15" />

                            </Grid>

                        </VerticalStackLayout>

                    </VerticalStackLayout>

                </Frame>

            </DataTemplate>

        </CollectionView.ItemTemplate>

    </CollectionView>

</ContentPage>