<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.VoluntariosPage"
    Title="Voluntários">

    <VerticalStackLayout Padding="25" Spacing="15">

        <Label
            Text="Gestão de Voluntários"
            FontSize="24"
            FontAttributes="Bold" />

        <Entry Placeholder="Nome do voluntário" />
        <Entry Placeholder="Telefone" />
        <Entry Placeholder="Função" />

        <Button Text="Salvar Voluntário" />

    </VerticalStackLayout>

</ContentPage>