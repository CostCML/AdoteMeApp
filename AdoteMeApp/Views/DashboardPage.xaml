<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.DashboardPage"
    Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="25" Spacing="20">

            <Label
                Text="Painel Principal da ONG"
                FontSize="26"
                FontAttributes="Bold" />

            <Frame Padding="15">
                <VerticalStackLayout>
                    <Label Text="Animais Disponíveis: 24" />
                    <Label Text="Voluntários Ativos: 12" />
                    <Label Text="Adoções Concluídas: 38" />
                    <Label Text="Parceiros Cadastrados: 7" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Gerenciar ONG" />
            <Button Text="Cadastrar Animal" />
            <Button Text="Visualizar Relatórios" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>