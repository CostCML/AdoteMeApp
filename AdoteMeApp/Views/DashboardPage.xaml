<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.DashboardPage"
    Title="Dashboard">

    <ScrollView>

        <VerticalStackLayout
            Padding="30"
            Spacing="25">

            <Label
                Text="Bem-vindo ao Adote-Me App"
                FontSize="30"
                FontAttributes="Bold" />

            <Button
                Text="Buscar ONGs próximas"
                Clicked="OnBuscarONGsClicked" />

            <Button
                Text="Animais disponíveis"
                Clicked="OnAnimaisClicked" />

            <Button
                Text="Meu perfil" />

            <Button
                Text="Minhas adoções" />

            <Button
                Text="Cadastrar Animal"
                Clicked="OnCadastrarAnimalClicked" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>