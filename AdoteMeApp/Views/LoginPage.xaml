<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.LoginPage"
    Title="Login">

    <ScrollView>

        <VerticalStackLayout
            Padding="30"
            Spacing="20"
            VerticalOptions="Center">

            <Label
                Text="Adote-Me App"
                FontSize="34"
                FontAttributes="Bold"
                HorizontalOptions="Center" />

            <Label
                Text="Faça login para continuar"
                HorizontalOptions="Center"
                TextColor="Gray" />

            <Entry
                x:Name="EmailEntry"
                Placeholder="Digite seu e-mail"
                Keyboard="Email" />

            <Entry
                x:Name="SenhaEntry"
                Placeholder="Digite sua senha"
                IsPassword="True" />

            <Button
                Text="Entrar"
                Clicked="OnEntrarClicked" />

            <Button
                Text="Cadastrar Adotante"
                Clicked="OnCadastroClicked" />

            <Button
                Text="Cadastrar ONG"
                Clicked="OnCadastroONGClicked" />

            <Button
                Text="Login Empresa Parceira"
                Clicked="OnLoginParceiroClicked" />

            <Button
                Text="Recuperar Senha"
                Clicked="OnRecuperarSenhaClicked" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>