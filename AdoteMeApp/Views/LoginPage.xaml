<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.LoginPage"
    BackgroundColor="#F8F8F8"
    NavigationPage.HasNavigationBar="False"
    xmlns:components="clr-namespace:AdoteMeApp.Components">

    <ScrollView>

        <VerticalStackLayout
            Padding="30"
            Spacing="18"
            VerticalOptions="Center">

            <!-- LOGO -->

            <Image
                Source="logo.png"
                HeightRequest="220"
                HorizontalOptions="Center"
                Margin="0,30,0,10" />

            <!-- TITULO -->

            <Label
                Text="Bem-vindo"
                FontSize="34"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#222" />

            <Label
                Text="Faça login para continuar"
                FontSize="16"
                HorizontalOptions="Center"
                TextColor="#777" />

            <!-- EMAIL -->

            <Frame
                CornerRadius="14"
                Padding="10,2"
                HasShadow="False"
                BorderColor="#E2E2E2"
                BackgroundColor="White">

                <Entry
                    x:Name="EmailEntry"
                    Placeholder="Digite seu e-mail"
                    Keyboard="Email"
                    TextColor="#222"
                    PlaceholderColor="#999" />

            </Frame>

            <!-- SENHA -->

            <Frame
                CornerRadius="14"
                Padding="10,2"
                HasShadow="False"
                BorderColor="#E2E2E2"
                BackgroundColor="White">

                <Entry
                    x:Name="SenhaEntry"
                    Placeholder="Digite sua senha"
                    IsPassword="True"
                    TextColor="#222"
                    PlaceholderColor="#999" />

            </Frame>

            <!-- LOGIN -->

            <Button
                Text="Entrar"
                HeightRequest="55"
                CornerRadius="14"
                BackgroundColor="#5B2BE0"
                TextColor="White"
                FontAttributes="Bold"
                FontSize="18"
                Clicked="OnEntrarClicked" />

            <!-- RECUPERAR -->

            <Button
                Text="Recuperar senha"
                BackgroundColor="Transparent"
                TextColor="#5B2BE0"
                FontSize="15"
                Clicked="OnRecuperarSenhaClicked" />

            <!-- SEPARADOR -->

            <BoxView
                HeightRequest="1"
                BackgroundColor="#DDDDDD"
                Margin="0,10" />

            <!-- OPÇÕES SECUNDÁRIAS -->

            <Label
                Text="Outras opções"
                FontSize="14"
                HorizontalOptions="Center"
                TextColor="#888" />

            <!-- CADASTRO -->

            <Button
                Text="Cadastrar adotante"
                FontSize="14"
                HeightRequest="45"
                BackgroundColor="#ECE8FF"
                TextColor="#5B2BE0"
                CornerRadius="12"
                Clicked="OnCadastroClicked" />

            <!-- ONG -->

            <Button
                Text="Cadastrar ONG"
                FontSize="14"
                HeightRequest="45"
                BackgroundColor="#ECE8FF"
                TextColor="#5B2BE0"
                CornerRadius="12"
                Clicked="OnCadastroONGClicked" />

            <!-- PARCEIRO -->

            <Button
                Text="Login empresa parceira"
                FontSize="14"
                HeightRequest="45"
                BackgroundColor="#ECE8FF"
                TextColor="#5B2BE0"
                CornerRadius="12"
                Clicked="OnLoginParceiroClicked" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>