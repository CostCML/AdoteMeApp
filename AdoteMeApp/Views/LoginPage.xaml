<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="AdoteMeApp.Views.LoginPage"
    Title="Login">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">

            <Label
                Text="Adote-Me App"
                FontSize="32"
                HorizontalOptions="Center"
                FontAttributes="Bold" />

            <Label
                Text="Login do Sistema"
                FontSize="20"
                HorizontalOptions="Center" />

            <Entry Placeholder="E-mail" />

            <Entry Placeholder="Senha" IsPassword="True" />

            <Button
                Text="Entrar"
                HeightRequest="50" />

            <Button
                Text="Cadastrar como Adotante"
                Clicked="OnCadastroAdotanteClicked" />

            <Button
                Text="Solicitar Parceria Empresarial"
                Clicked="OnSolicitarParceriaClicked" />

            <Button
                Text="Login Empresa Parceira"
                Clicked="OnLoginParceiroClicked" />

            <Button
                Text="Login Administrativo ONG"
                Clicked="OnLoginAdminClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>