<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:AdoteMeApp.Components"
    x:Class="AdoteMeApp.Views.BuscarONGsPage"
    Title="ONGs Próximas">

    <VerticalStackLayout
        Padding="20"
        Spacing="15">

        <components:AppHeader />

        <Label
            Text="ONGs próximas de você"
            FontSize="28"
            FontAttributes="Bold" />

        <Button
            Text="Buscar ONGs próximas"
            Clicked="OnBuscarClicked" />

        <Button
            Text="Ver no mapa"
            Clicked="OnMapaClicked" />

        <CollectionView
            x:Name="OngsCollection">

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Frame
                        Padding="15"
                        Margin="0,5">

                        <VerticalStackLayout
                            Spacing="5">

                            <Label
                                Text="{Binding NomeONG}"
                                FontSize="22"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding Endereco}" />

                            <Label
                                Text="{Binding Telefone}" />

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>