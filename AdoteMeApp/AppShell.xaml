<?xml version="1.0" encoding="UTF-8" ?>

<Shell
    x:Class="AdoteMeApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AdoteMeApp.Views"

    Shell.BackgroundColor="White"
    Shell.ForegroundColor="#777"
    Shell.TitleColor="#5B2BE0"
    Shell.UnselectedColor="#999">

    <TabBar>

        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate views:BuscarONGsPage}" />

        <ShellContent
            Title="Animais"
            ContentTemplate="{DataTemplate views:AnimaisDisponiveisPage}" />

        <ShellContent
            Title="Favoritos"
            ContentTemplate="{DataTemplate views:FavoritosPage}" />

        <ShellContent
            Title="Perfil"
            ContentTemplate="{DataTemplate views:PerfilPage}" />

    </TabBar>

</Shell>